---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaBlock from '../components/CtaBlock.astro';

const slug = '/calculators';

// One entry per live calculator, in the order shown. Add a new calculator here
// when its page is on main so this hub lists it.
const CALCULATORS = [
  {
    title: 'Loan to value (LTV) calculator',
    href: '/loan-to-value-calculator',
    line: 'Turn a property value and deposit into your loan to value and the lending band it falls in, plus the deposit needed to reach the band below.',
  },
  {
    title: 'Foreign currency mortgage borrowing calculator',
    href: '/foreign-currency-mortgage-calculator',
    line: 'See an indicative UK borrowing range on income paid in a foreign currency, from a cautious lender to a generous specialist.',
  },
  {
    title: 'Self-employed mortgage calculator',
    href: '/self-employed-mortgage-calculator',
    line: 'See an indicative UK borrowing range when you are self-employed, for sole traders, partnerships and company directors at 4.5 to 5 times income.',
  },
  {
    title: 'Limited company buy-to-let calculator',
    href: '/limited-company-buy-to-let-calculator',
    line: 'See an indicative limited company buy-to-let borrowing range from your rent, on a 125% cover basis, with a 75% loan to value cross-check.',
  },
  {
    title: 'Guarantor and JBSP mortgage calculator',
    href: '/guarantor-jbsp-mortgage-calculator',
    line: 'See how much more you could borrow when a family helper or guarantor is added on a Joint Borrower Sole Proprietor (JBSP) basis, at 4.5 to 5 times combined income.',
  },
  {
    title: 'Remortgage calculator',
    href: '/remortgage-calculator',
    line: 'See what you could save each month and each year by moving from your current rate to a new one, with a fee break-even on a capital repayment basis.',
  },
  {
    title: 'Second home mortgage calculator',
    href: '/second-home-mortgage-calculator',
    line: 'See an indicative borrowing range for a second home, on your income at 4.5 to 5 times income after your existing main-home mortgage. Affordability only.',
  },
  {
    title: 'Stamp duty calculator',
    href: 'https://www.mortgageonefinance.co.uk/stamp-duty-calculator',
    line: 'Work out the stamp duty land tax due on a property purchase. Opens on the main Mortgage One site.',
  },
];
---

<BaseLayout
  title="Mortgage Calculators | Mortgage One"
  description="Free mortgage calculators from Mortgage One. Work out your loan to value and an indicative borrowing range on foreign currency income, illustrative only."
  breadcrumbs={[
    { name: 'Home', href: '/' },
    { name: 'Calculators', href: slug },
  ]}
>
  <section class="section">
    <div class="container calc-index">
      <p class="eyebrow">Mortgage tools</p>
      <h1>Mortgage calculators</h1>

      <p class="lead">
        Yes, you can work out the key numbers before you speak to a lender. These free calculators give you an indicative
        starting point, and a Mortgage One adviser can then turn the figure into a lender shortlist built around your
        case.
      </p>

      <div class="grid grid--3 calc-cards">
        {CALCULATORS.map((c) => (
          <a class="card calc-card" href={c.href}>
            <span class="calc-card__title">{c.title}</span>
            <span class="calc-card__line">{c.line}</span>
            <span class="calc-card__go">Open calculator</span>
          </a>
        ))}
      </div>

      <p class="calc-note">
        Every figure is illustrative only. It is not a quote, offer or advice. Actual borrowing is subject to full lender
        assessment and status.
      </p>

      <CtaBlock
        heading="Find the figure that moves your application"
        line="Tell us your situation and a Mortgage One adviser will point you to the number that moves your application."
        src={slug}
      />

      <p class="risk-warning">
        Think carefully before securing your debts against your home. Your home may be repossessed if you do not keep up
        repayments on your mortgage.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .calc-index {
    max-width: 760px;
  }
  .calc-cards {
    margin-block: 2rem;
  }
  .calc-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s ease, transform 0.15s ease;
  }
  .calc-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }
  .calc-card__title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.15rem;
  }
  .calc-card__line {
    color: var(--ink-soft);
    font-size: 0.95rem;
    line-height: 1.5;
  }
  .calc-card__go {
    margin-top: auto;
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--accent-strong);
  }
  .calc-note {
    font-size: 0.85rem;
    color: var(--ink-soft);
    line-height: 1.5;
  }
  .risk-warning {
    border-top: 1px solid var(--line);
    padding-top: 1.5rem;
    margin-top: 2.5rem;
  }
</style>
