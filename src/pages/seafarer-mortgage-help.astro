const slug = '/seafarer-mortgage-help';

const reassuranceLines = [
  'Paid in a foreign currency (USD, EUR or other)',
  'Working rotational or voyage-based contracts',
  "Claiming Seafarers' Earnings Deduction (SED)",
  'Spending long stretches outside the UK',
  'Merchant navy, yacht, cruise or offshore crew',
  'Mixing salary, allotments and overtime',
];

const faqs = [
  {
    q: 'Do I need a specialist broker for a seafarer mortgage?',
    a: 'It helps a great deal. Seafarer income is read very differently from one lender to the next, and a broker who places these cases regularly knows which lenders treat your pay fairly. The work is in matching your circumstances to the right lender, not in the eligibility itself.',
  },
  {
    q: 'Will the Seafarers Earnings Deduction stop me getting a mortgage?',
    a: 'No. The deduction lowers your UK tax, not your earnings. A lender that understands seafarers works from your gross contractual pay rather than the low tax figure on your return, so the relief is not the obstacle. Lender choice is.',
  },
  {
    q: 'Can I get help if I am working abroad right now?',
    a: 'We can start a conversation, but you must be on UK soil to receive advice. We confirm your residency and circumstances properly before recommending anything, so the advice fits where you genuinely stand.',
  },
  {
    q: 'How do I start?',
    a: 'Use the 60-second check and a Mortgage One adviser will review your answers and tell you where you stand. You can also call us on 01202 155992. You must be on UK soil to receive advice.',
  },
];

const relatedCards = [
  { title: 'Mortgages for seafarers', href: '/mortgage-as-a-seafarer', line: 'The full picture for seafarer mortgages.' },
  { title: 'Foreign currency income', href: '/seafarer-mortgage-foreign-currency-income', line: 'How lenders convert and discount non-sterling pay.' },
  { title: 'Seafarers Earnings Deduction mortgages', href: '/seafarers-earnings-deduction-mortgage', line: 'Getting a mortgage while you claim the Seafarers Earnings Deduction.' },
  { title: 'Merchant navy mortgages', href: '/merchant-navy-mortgage', line: 'Specialist help for merchant navy pay.' },
  { title: 'Check your eligibility', href: '/check', line: 'Five quick questions, about 60 seconds.' },
