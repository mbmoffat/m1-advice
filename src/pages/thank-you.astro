---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../config/site';
---

<BaseLayout
  title="Thank You | Mortgage One"
  description="Your details are with the Mortgage One team and an adviser will be in touch."
  noindex={true}
>
  <section class="section">
    <div class="container thanks">
      <h1>Thank you, your details are with us</h1>
      <p>
        A Mortgage One adviser will review your answers and aims to come back to you within one working day. Need us
        sooner? Call <a href={site.phoneHref}>01202 155992</a>.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .thanks {
    max-width: 680px;
  }
</style>
