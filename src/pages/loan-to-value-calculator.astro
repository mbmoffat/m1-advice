---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaBlock from '../components/CtaBlock.astro';
import site from '../config/site';

const slug = '/loan-to-value-calculator';
const canonical = site.host + slug;

// Lending bands, ascending. A result sits in the lowest band whose ceiling it
// does not exceed. Lenders price in steps at these points, so showing the band
// and the deposit needed to reach the next one down is the useful output.
const BANDS = [60, 75, 80, 85, 90, 95];

const webApplication = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Loan to value (LTV) calculator',
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'Any',
  isAccessibleForFree: true,
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'GBP' },
  description:
    'A calculator that works out your loan to value from a property value and your deposit, shows the lending band it falls in, and the extra deposit needed to reach the band below.',
  provider: {
    '@type': 'Organization',
    name: 'Mortgage One',
    url: site.www,
  },
};
---

<BaseLayout
  title="Loan to Value (LTV) Calculator | Mortgage One"
  description="Work out your loan to value in seconds. Enter a property value and your deposit or loan, see the lending band, the deposit to reach the band below and a typical maximum LTV."
  breadcrumbs={[
    { name: 'Home', href: '/' },
    { name: 'Loan to value calculator', href: slug },
  ]}
>
  <section class="section">
    <div class="container calc">
      <p class="eyebrow">Mortgage tools</p>
      <h1>Loan to value (LTV) calculator</h1>

      <p>
        Yes, you can work out your loan to value in a few seconds. Enter the property value and your deposit below, and
        this tool shows your LTV, the lending band it falls in, and how much more deposit would move you into the band
        below.
      </p>

      <p>
        Loan to value is simply the loan measured against the property value, written as a percentage. It matters because
        lenders price and set their criteria in bands, so dropping under the next band down can widen the lenders open to
        you and improve the rate. This calculator shows where you sit and what it would take to step down a band.
      </p>

      <div class="calc-form" id="ltv-calc">
        <div class="field">
          <label for="ltv-value">Property value</label>
          <input
            id="ltv-value"
            name="propertyValue"
            type="number"
            inputmode="numeric"
            min="0"
            step="1000"
            placeholder="e.g. 350000"
          />
        </div>

        <div class="field">
          <label for="ltv-deposit">Deposit amount</label>
          <input
            id="ltv-deposit"
            name="deposit"
            type="number"
            inputmode="numeric"
            min="0"
            step="1000"
            placeholder="e.g. 70000"
          />
          <p class="field-note">We work out the loan as the property value minus your deposit.</p>
        </div>

        <button type="button" class="btn" id="ltv-calc-btn">Work out my LTV</button>
      </div>

      <div class="result" id="ltv-result" hidden>
        <p class="result-eyebrow">Your result</p>
        <div class="result-headline">
          <span class="result-figure" id="ltv-figure">75%</span>
          <span class="result-caption">loan to value</span>
        </div>
        <p class="result-band" id="ltv-band"></p>

        <table class="result-table">
          <tbody>
            <tr>
              <th scope="row">Loan amount</th>
              <td id="ltv-out-loan"></td>
            </tr>
            <tr>
              <th scope="row">Deposit</th>
              <td id="ltv-out-deposit"></td>
            </tr>
            <tr>
              <th scope="row">Lending band</th>
              <td id="ltv-out-bandcell"></td>
            </tr>
            <tr>
              <th scope="row">To reach the band below</th>
              <td id="ltv-out-gap"></td>
            </tr>
          </tbody>
        </table>

        <p class="result-insight">LTV is your loan as a share of the property value.</p>

        <p class="result-insight">
          Lenders price in bands, so a slightly larger deposit that tips you into a lower band can open up more lenders
          and a sharper rate.
        </p>

        <p class="result-disclaimer">
          Figures are illustrative. Maximum LTV varies by lender, product and your full circumstances. Specialist
          scenarios often have lower maximums.
        </p>

        <p class="result-disclaimer">
          These figures are illustrative only. They are not a quote, offer or advice. Actual borrowing is subject to full
          lender assessment and status.
        </p>
      </div>

      <CtaBlock
        tone="accent"
        heading="See which lenders fit your loan to value"
        line="Tell us your property value and your deposit, and a Mortgage One adviser will turn this band into a shortlist of lenders built around your case."
        scenario=""
        src={slug}
      />

      <p class="risk-warning">
        Think carefully before securing your debts against your home. Your home may be repossessed if you do not keep up
        repayments on your mortgage.
      </p>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(webApplication)} is:inline />

  <script define:vars={{ bands: BANDS }}>
    const form = document.getElementById('ltv-calc');
    const result = document.getElementById('ltv-result');
    if (form && result) {
      const gbp = new Intl.NumberFormat('en-GB', {
        style: 'currency',
        currency: 'GBP',
        maximumFractionDigits: 0,
      });
      const money = (n) => gbp.format(Math.round(n));
      // Deposit gap is rounded up to the nearest hundred so it is never understated.
      const moneyUp = (n) => gbp.format(Math.ceil(n / 100) * 100);
      // LTV to one decimal, with a whole number left clean: 75 not 75.0.
      const pct = (n) => {
        const r = Math.round(n * 10) / 10;
        return (r % 1 === 0 ? String(r) : r.toFixed(1)) + '%';
      };

      const set = (id, value) => {
        const el = document.getElementById(id);
        if (el) el.textContent = value;
      };

      // Lowest band whose ceiling the LTV does not exceed. null means above the top band.
      const bandFor = (ltv) => {
        for (const b of bands) {
          if (ltv <= b) return b;
        }
        return null;
      };

      const calculate = () => {
        const propertyValue = Math.max(0, Number(document.getElementById('ltv-value').value) || 0);
        const deposit = Math.max(0, Number(document.getElementById('ltv-deposit').value) || 0);

        if (propertyValue <= 0) {
          result.hidden = true;
          return;
        }

        const loan = propertyValue - deposit;
        const ltv = (loan / propertyValue) * 100;

        set('ltv-out-loan', money(Math.max(0, loan)));
        set('ltv-out-deposit', money(Math.max(0, deposit)));

        // Deposit covers the whole property value, so there is no loan to measure.
        if (loan <= 0) {
          set('ltv-figure', '0%');
          set('ltv-band', 'Your deposit covers the whole property value, so there is no loan to measure.');
          set('ltv-out-bandcell', 'No borrowing needed');
          set('ltv-out-gap', 'Not applicable');
          result.hidden = false;
          return;
        }

        set('ltv-figure', pct(ltv));

        // Band labels never contain the word "band": the sentence and table add
        // their own context, so a label is just the bracket, e.g. "up to 60%".
        const band = bandFor(ltv);
        let label;
        let nextLower;
        let lowerLabel;
        if (band === null) {
          label = 'above 95%';
          nextLower = 95;
          lowerLabel = 'up to 95%';
        } else {
          label = 'up to ' + band + '%';
          const idx = bands.indexOf(band);
          nextLower = idx > 0 ? bands[idx - 1] : null;
          lowerLabel = nextLower === null ? null : 'up to ' + nextLower + '%';
        }

        if (band === 60) {
          set(
            'ltv-band',
            'Your ' + pct(ltv) + ' LTV falls in the up to 60% band. That is the strongest band for lender choice and rates.'
          );
        } else {
          set('ltv-band', 'Your ' + pct(ltv) + ' LTV falls in the ' + label + ' band.');
        }

        set('ltv-out-bandcell', label.charAt(0).toUpperCase() + label.slice(1));

        if (nextLower === null) {
          set('ltv-out-gap', 'You are already in the strongest band.');
        } else {
          const targetLoan = propertyValue * (nextLower / 100);
          const extra = loan - targetLoan;
          set('ltv-out-gap', 'Add ' + moneyUp(extra) + ' deposit to reach ' + lowerLabel + '.');
        }

        result.hidden = false;
      };

      document.getElementById('ltv-calc-btn').addEventListener('click', calculate);
      form.addEventListener('input', () => {
        if (!result.hidden) calculate();
      });
    }
  </script>
</BaseLayout>

<style>
  .calc {
    max-width: 760px;
  }
  .calc-form {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 1.75rem;
    margin-block: 2rem;
    max-width: 640px;
  }
  .field {
    margin-bottom: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .field label {
    font-weight: 700;
    font-size: 0.95rem;
  }
  .field input,
  .field select {
    font-family: var(--font-body);
    font-size: 1rem;
    padding: 0.7rem 0.8rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--bg);
    width: 100%;
  }
  .field-note {
    font-size: 0.85rem;
    color: var(--ink-soft);
    margin: 0.1rem 0 0;
  }
  .result {
    border: 1px solid var(--line);
    border-top: 4px solid var(--accent);
    border-radius: var(--radius);
    padding: clamp(1.5rem, 4vw, 2.25rem);
    margin-block: 2.5rem;
    background: var(--surface);
  }
  .result-eyebrow {
    font-family: var(--font-body);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.78rem;
    color: var(--ink-soft);
    margin: 0 0 0.4rem;
  }
  .result-headline {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-bottom: 1rem;
  }
  .result-figure {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: clamp(3rem, 11vw, 4.75rem);
    line-height: 1;
    color: var(--accent-strong);
  }
  .result-caption {
    font-family: var(--font-heading);
    font-size: clamp(1.1rem, 3vw, 1.5rem);
    color: var(--ink-soft);
  }
  .result-band {
    display: inline-block;
    font-weight: 700;
    margin: 0;
    padding: 0.55rem 0.9rem;
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: var(--radius);
  }
  .result-table {
    width: 100%;
    border-collapse: collapse;
    margin-block: 1.5rem;
    font-size: 0.95rem;
  }
  .result-table th,
  .result-table td {
    text-align: left;
    padding: 0.6rem 0.5rem;
    border-bottom: 1px solid var(--line);
  }
  .result-table th[scope='row'] {
    width: 45%;
    color: var(--ink-soft);
    font-weight: 700;
  }
  .result-insight {
    font-weight: 700;
  }
  .result-disclaimer {
    font-size: 0.85rem;
    color: var(--ink-soft);
    line-height: 1.5;
  }
  .risk-warning {
    border-top: 1px solid var(--line);
    padding-top: 1.5rem;
    margin-top: 2.5rem;
  }
</style>
