---
import BaseLayout from '../layouts/BaseLayout.astro';

// Built from the same live page set as sitemap.xml: every page under src/pages
// except 404 and thank-you (the @astrojs/sitemap exclusions). Rebuilds itself
// whenever a page is rolled out or removed.
const pageModules = import.meta.glob('./**/*.astro');
const exclude = new Set(['/404', '/thank-you']);
const routes = Object.keys(pageModules)
  .map((p) => {
    const r = p.replace(/^\.\//, '/').replace(/\.astro$/, '').replace(/\/index$/, '');
    return r === '' ? '/' : r;
  })
  .filter((r) => !exclude.has(r));
// import.meta.glob excludes this file itself, so add its own route to match
// the sitemap.xml page set exactly.
if (!routes.includes('/sitemap')) routes.push('/sitemap');

const label = (r) => {
  if (r === '/') return 'Home';
  if (r === '/check') return 'Check your eligibility';
  if (r === '/sitemap') return 'Sitemap';
  if (r === '/mortgage-as-a-seafarer') return 'Mortgages for seafarers';
  const s = r.replace(/^\//, '').replace(/-/g, ' ');
  return s.charAt(0).toUpperCase() + s.slice(1);
};

// Top-level pages sit under General; clusters group under their hub name, pillar first.
const topLevel = new Set(['/', '/check', '/sitemap']);
const hubOf = (r) => {
  if (topLevel.has(r)) return 'General';
  if (/seafarer|merchant-navy|offshore-worker/.test(r)) return 'Seafarer mortgages';
  return 'Other pages';
};
const pillarOf = { General: '/', 'Seafarer mortgages': '/mortgage-as-a-seafarer' };
const hubOrder = ['General', 'Seafarer mortgages', 'Other pages'];

const hubs = hubOrder
  .map((hub) => {
    const pillar = pillarOf[hub];
    const pages = routes
      .filter((r) => hubOf(r) === hub)
      .sort((a, b) => {
        if (a === pillar) return -1;
        if (b === pillar) return 1;
        return label(a).localeCompare(label(b));
      });
    return { hub, pages };
  })
  .filter((g) => g.pages.length);
---

<BaseLayout
  title="Sitemap | Mortgage One"
  description="Every page on the Mortgage One advice site, grouped by topic, including the seafarer mortgage guides and the 60-second eligibility check."
  breadcrumbs={[{ name: 'Home', href: '/' }, { name: 'Sitemap', href: '/sitemap' }]}
>
  <section class="section">
    <div class="container sitemap">
      <h1>Sitemap</h1>
      <p class="sitemap-intro">Every page on this site, grouped by topic. The list updates itself whenever a new page goes live.</p>
      {hubs.map((group) => (
        <div class="sitemap-hub">
          <h2>{group.hub}</h2>
          <ul>
            {group.pages.map((route) => (
              <li><a href={route}>{label(route)}</a></li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .sitemap {
    max-width: 760px;
  }
  .sitemap-intro {
    font-size: 1.2rem;
    margin: 0 0 2rem;
  }
  .sitemap-hub {
    margin-bottom: 2rem;
  }
  .sitemap-hub h2 {
    margin-bottom: 0.75rem;
  }
  .sitemap-hub ul {
    margin: 0;
    padding-left: 1.2rem;
  }
  .sitemap-hub li {
    margin-bottom: 0.5rem;
  }
</style>
