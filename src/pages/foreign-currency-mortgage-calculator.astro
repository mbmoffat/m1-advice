---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaBlock from '../components/CtaBlock.astro';
import ForeignCurrencyCalculator from '../components/calculators/ForeignCurrencyCalculator.astro';
import site from '../config/site';

const slug = '/foreign-currency-mortgage-calculator';
const canonical = site.host + slug;

const webApplication = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Foreign currency mortgage borrowing calculator',
  url: canonical,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'Any',
  isAccessibleForFree: true,
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'GBP' },
  description:
    'An indicative calculator that shows how much you might borrow on UK mortgage when part of your income is paid in a foreign currency, across a generous, typical and cautious lender treatment.',
  provider: {
    '@type': 'Organization',
    name: 'Mortgage One',
    url: site.www,
  },
};
---

<BaseLayout
  title="Foreign Currency Mortgage Borrowing Calculator | Mortgage One"
  description="See an indicative UK mortgage borrowing range on foreign currency income. Generous, typical and cautious lender treatments at 4.5 to 5 times income, illustrative only."
  breadcrumbs={[
    { name: 'Home', href: '/' },
    { name: 'Foreign currency mortgage borrowing calculator', href: slug },
  ]}
>
  <section class="section">
    <div class="container calc">
      <p class="eyebrow">Foreign currency mortgage tools</p>
      <h1>Foreign currency mortgage borrowing calculator</h1>

      <p class="lead">
        Yes, you can get a sense of what you might borrow on income paid in a foreign currency in a few seconds. Enter
        your pay below and this tool shows an indicative borrowing range, from a cautious lender to a generous
        specialist, so you can see how much the choice of lender moves the figure.
      </p>

      <p>
        The reason there is a range, rather than a single number, is that lenders treat foreign currency pay very
        differently. One converts your income to sterling and lends on all of it. The next holds back a quarter to allow
        for the exchange rate moving. This calculator puts those treatments side by side so the spread is plain before
        you ever speak to a lender.
      </p>

      <ForeignCurrencyCalculator />

      <CtaBlock
        tone="accent"
        heading="See what a lender would really assess"
        line="Tell us how you are paid and a Mortgage One adviser will turn this indicative range into a figure built around your case."
        scenario="foreign-currency"
        src={slug}
      />

      <p class="risk-warning">
        Think carefully before securing your debts against your home. Your home may be repossessed if you do not keep up
        repayments on your mortgage.
      </p>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(webApplication)} is:inline />
</BaseLayout>
