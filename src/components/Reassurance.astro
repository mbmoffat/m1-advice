---
interface Props {
  title: string;
  lines: string[];
}
const { title, lines } = Astro.props;
---

<div class="reassurance card">
  <h2>{title}</h2>
  <ul>
    {lines.map((line) => (
      <li>{line}</li>
    ))}
  </ul>
</div>

<style>
  .reassurance {
    margin-block: 2rem;
  }
  .reassurance h2 {
    margin-top: 0;
    font-size: 1.4rem;
  }
  .reassurance ul {
    margin: 0;
    padding-left: 1.2rem;
    display: grid;
    gap: 0.5rem;
  }
</style>
