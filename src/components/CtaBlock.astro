---
import Trustpilot from './Trustpilot.astro';

interface Props {
  heading: string;
  // Accepted for backwards compatibility but no longer rendered; CTA blocks
  // show the heading and button only.
  line?: string | string[];
  label?: string;
  scenario?: string;
  src?: string;
  tone?: 'dark' | 'accent';
}
// The end CTA box carries the brand maroon by default. Pass tone="dark" for the
// near-black treatment on a page that needs it.
const { heading, label = 'Check Your Eligibility', scenario = '', src = '', tone = 'accent' } = Astro.props;

const query = new URLSearchParams();
if (scenario) query.set('scenario', scenario);
if (src) query.set('src', src);
const href = query.toString() ? `/check?${query.toString()}` : '/check';
---

<div class="cta-block-wrap">
  <div class:list={['cta-block', 'section--dark', tone === 'accent' && 'cta-block--accent']}>
    <div class="cta-block__inner">
      <h2>{heading}</h2>
      <a class="btn" href={href}>{label}</a>
    </div>
  </div>
  <div class="cta-block__trust">
    <Trustpilot />
  </div>
</div>

<style>
  /* Contained and centred, a little under the 760px article column, so the
     box stays inviting rather than a full-width slab on any page. The trust
     line rides just beneath it within the same width. */
  .cta-block-wrap {
    max-width: 710px;
    margin: 3rem auto;
  }
  .cta-block {
    border-radius: var(--radius);
    padding: clamp(2rem, 5vw, 3rem);
    text-align: center;
  }
  /* Accent tone keeps the full-bleed box and light text, but swaps the near-black
     background for the brand maroon so the whole panel carries the colour. */
  .cta-block.cta-block--accent {
    background: var(--accent-strong);
  }
  .cta-block__inner {
    max-width: 640px;
    margin-inline: auto;
  }
  .cta-block__trust {
    margin-top: 1.25rem;
  }
  .cta-block h2 {
    margin: 0 0 1.5rem;
  }
  .cta-block .btn {
    background: var(--dark-ink);
    color: var(--ink);
  }
  .cta-block .btn:hover {
    background: var(--line);
    color: var(--ink);
  }
</style>
