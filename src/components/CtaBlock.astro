---
interface Props {
  heading: string;
  line: string | string[];
  label?: string;
  scenario?: string;
  src?: string;
  tone?: 'dark' | 'accent';
}
// The end CTA box carries the brand maroon by default. Pass tone="dark" for the
// near-black treatment on a page that needs it.
const { heading, line, label = 'Check Your Eligibility', scenario = '', src = '', tone = 'accent' } = Astro.props;

// Accept a single string or several, so a CTA can carry more than one paragraph.
const lines = Array.isArray(line) ? line : [line];

const query = new URLSearchParams();
if (scenario) query.set('scenario', scenario);
if (src) query.set('src', src);
const href = query.toString() ? `/check?${query.toString()}` : '/check';
---

<div class:list={['cta-block', 'section--dark', tone === 'accent' && 'cta-block--accent']}>
  <div class="cta-block__inner">
    <h2>{heading}</h2>
    {lines.map((l) => <p>{l}</p>)}
    <a class="btn" href={href}>{label}</a>
  </div>
</div>

<style>
  .cta-block {
    /* Contained and centred, a little under the 760px article column, so the
       box stays inviting rather than a full-width slab on any page. */
    max-width: 710px;
    margin: 3rem auto;
    border-radius: var(--radius);
    padding: clamp(2rem, 5vw, 3rem);
    text-align: center;
  }
  /* Accent tone keeps the full-bleed box and light text, but swaps the near-black
     background for the brand maroon so the whole panel carries the colour. */
  .cta-block.cta-block--accent {
    background: var(--accent-strong);
  }
  .cta-block__inner {
    max-width: 640px;
    margin-inline: auto;
  }
  .cta-block h2 {
    margin-top: 0;
  }
  .cta-block p {
    font-size: 1.1rem;
    margin: 0 0 0.35rem;
  }
  /* Keep the usual breathing space before the button, but let stacked
     paragraphs sit close together rather than a full line apart. */
  .cta-block p:last-of-type {
    margin-bottom: 1.5rem;
  }
  .cta-block .btn {
    background: var(--dark-ink);
    color: var(--ink);
  }
  .cta-block .btn:hover {
    background: var(--line);
    color: var(--ink);
  }
</style>
